#-----------------------------------------------------

# GET /api/produtos/{id} - produto não existe

### adicionar stub
POST http://localhost:2525/imposters/3002/stubs
Content-Type: application/json

{
  "stub": {
    "predicates": [
      {
        "equals": {
          "method": "GET",
          "path": "/api/produtos/99"
        }
      }
    ],
    "responses": [
      {
        "is": {
          "statusCode": 404,
          "headers": { "Content-Type": "application/json" },
          "body": {
            "error": "not_found",
            "message": "produto não encontrado"
          }
        }
      }
    ]
  }
}

### testar produto existente
GET http://localhost:3002/api/produtos/1

### testar produto inexistente
GET http://localhost:3002/api/produtos/99

#-----------------------------------------------------

# POST /api/produtos - quantidade negativa (específico - primeiro!)

### adicionar stub
POST http://localhost:2525/imposters/3002/stubs
Content-Type: application/json

{
  "stub": {
    "predicates": [
      {
        "equals": {
          "method": "POST",
          "path": "/api/produtos",
          "headers": { "Content-Type": "application/json" }
        }
      },
      {
        "contains": { "body": "\"quantidade\":-" }
      }
    ],
    "responses": [
      {
        "is": {
          "statusCode": 400,
          "headers": { "Content-Type": "application/json" },
          "body": {
            "error": "quantidade_invalida",
            "message": "Valor inválido"
          }
        }
      }
    ]
  }
}

### testar quantidade negativa
POST http://localhost:3002/api/produtos
Content-Type: application/json

{"nome":"Monitor","preco":199.99,"quantidade":-5}

#-----------------------------------------------------

# POST /api/produtos - sucesso (genérico - depois!)

### adicionar stub
POST http://localhost:2525/imposters/3002/stubs
Content-Type: application/json

{
  "stub": {
    "predicates": [
      {
        "equals": {
          "method": "POST",
          "path": "/api/produtos",
          "headers": { "Content-Type": "application/json" }
        }
      }
    ],
    "responses": [
      {
        "is": {
          "statusCode": 201,
          "headers": { "Content-Type": "application/json" },
          "body": {
            "id": 3,
            "status": "created",
            "message": "produto adicionado com sucesso"
          }
        }
      }
    ]
  }
}

### testar post válido
POST http://localhost:3002/api/produtos
Content-Type: application/json

{"nome":"Monitor","preco":199.99,"quantidade":10}

