#-----------------------------------------------------

# GET /api/clientes/{id}/pedidos - lista pedidos do cliente

### adicionar stub
POST http://localhost:2525/imposters/3007/stubs
Content-Type: application/json

{
  "stub": {
    "predicates": [
      {
        "equals": {
          "method": "GET",
          "path": "/api/clientes/1/pedidos"
        }
      }
    ],
    "responses": [
      {
        "is": {
          "statusCode": 200,
          "headers": { "Content-Type": "application/json" },
          "body": {
            "cliente_id": 1,
            "pedidos": [
              { "id": 1, "produto": "Teclado", "quantidade": 2, "estado": "Enviado" },
              { "id": 2, "produto": "Rato", "quantidade": 1, "estado": "Em processamento" }
            ]
          }
        }
      }
    ]
  }
}

