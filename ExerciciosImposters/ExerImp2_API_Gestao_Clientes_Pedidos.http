POST http://localhost:2525/imposters/3007/stubs
Content-Type: application/json

{
  "stub": {
    "predicates": [
      {
        "equals": {
          "method": "DELETE",
          "path": "/api/pedidos/2"
        }
      }
    ],
    "responses": [
      {
        "is": {
          "statusCode": 200,
          "headers": { "Content-Type": "application/json" },
          "body": {
            "status": "deleted",
            "message": "pedido cancelado com sucesso"
          }
        }
      }
    ]
  }
}

#-----------------------------------------------------

# DELETE /api/pedidos/{id} - pedido já enviado (não pode cancelar)

### adicionar stub
POST http://localhost:2525/imposters/3007/stubs
Content-Type: application/json

{
  "stub": {
    "predicates": [
      {
        "equals": {
          "method": "DELETE",
          "path": "/api/pedidos/1"
        }
      }
    ],
    "responses": [
      {
        "is": {
          "statusCode": 400,
          "headers": { "Content-Type": "application/json" },
          "body": {
            "error": "cancelamento_nao_permitido",
            "message": "só é possível cancelar pedidos em processamento"
          }
        }
      }
    ]
  }
}

