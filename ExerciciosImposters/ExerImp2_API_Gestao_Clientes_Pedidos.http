#=====================================================

# API 7 - Gestão de Clientes e Pedidos

### criar o imposter
POST http://localhost:2525/imposters
Content-Type: application/json

{
  "port": 3007,
  "protocol": "http"
}

#-----------------------------------------------------

# GET /api/clientes - lista todos os clientes

### adicionar stub
POST http://localhost:2525/imposters/3007/stubs
Content-Type: application/json

{
  "stub": {
    "predicates": [
      {
        "equals": {
          "method": "GET",
          "path": "/api/clientes"
        }
      }
    ],
    "responses": [
      {
        "is": {
          "statusCode": 200,
          "headers": { "Content-Type": "application/json" },
          "body": {
            "clientes": [
              { "id": 1, "nome": "David", "email": "david@exemplo.com" },
              { "id": 2, "nome": "Ana", "email": "ana@exemplo.com" }
            ]
          }
        }
      }
    ]
  }
}

### testar
GET http://localhost:3007/api/clientes

#-----------------------------------------------------

# POST /api/clientes - cliente inexistente (específico - primeiro!)

### adicionar stub
POST http://localhost:2525/imposters/3007/stubs
Content-Type: application/json

{
  "stub": {
    "predicates": [
      {
        "equals": {
          "method": "POST",
          "path": "/api/clientes",
          "headers": { "Content-Type": "application/json" }
        }
      },
      {
        "contains": { "body": "\"email\":\"existe@exemplo.com\"" }
      }
    ],
    "responses": [
      {
        "is": {
          "statusCode": 409,
          "headers": { "Content-Type": "application/json" },
          "body": {
            "error": "email_exists",
            "message": "este email já está registado"
          }
        }
      }
    ]
  }
}

### testar email duplicado
POST http://localhost:3007/api/clientes
Content-Type: application/json

{"nome":"Carlos","email":"existe@exemplo.com"}

#-----------------------------------------------------

# POST /api/clientes - sucesso (genérico - depois!)

### adicionar stub
POST http://localhost:2525/imposters/3007/stubs
Content-Type: application/json

{
  "stub": {
    "predicates": [
      {
        "equals": {
          "method": "POST",
          "path": "/api/clientes",
          "headers": { "Content-Type": "application/json" }
        }
      }
    ],
    "responses": [
      {
        "is": {
          "statusCode": 201,
          "headers": { "Content-Type": "application/json" },
          "body": {
            "id": 3,
            "status": "created",
            "message": "cliente adicionado com sucesso"
          }
        }
      }
    ]
  }
}

