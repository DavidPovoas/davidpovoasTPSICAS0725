#=====================================================

# API 3 - reset e recriar com ordem certa

### apagar
DELETE http://localhost:2525/imposters/3003

### recriar
POST http://localhost:2525/imposters
Content-Type: application/json

{
  "port": 3003,
  "protocol": "http"
}

### stub GET /api/reservas
POST http://localhost:2525/imposters/3003/stubs
Content-Type: application/json

{
  "stub": {
    "predicates": [
      {
        "equals": {
          "method": "GET",
          "path": "/api/reservas"
        }
      }
    ],
    "responses": [
      {
        "is": {
          "statusCode": 200,
          "headers": { "Content-Type": "application/json" },
          "body": {
            "reservas": [
              {
                "id": 1,
                "cliente": "David",
                "checkin": "2026-04-10",
                "checkout": "2026-04-15",
                "tipo_quarto": "duplo"
              },
              {
                "id": 2,
                "cliente": "Ana",
                "checkin": "2026-04-12",
                "checkout": "2026-04-14",
                "tipo_quarto": "single"
              }
            ]
          }
        }
      }
    ]
  }
}

### stub POST checkout inválido (específico - primeiro!)
POST http://localhost:2525/imposters/3003/stubs
Content-Type: application/json

{
  "stub": {
    "predicates": [
      {
        "equals": {
          "method": "POST",
          "path": "/api/reservas",
          "headers": { "Content-Type": "application/json" }
        }
      },
      {
        "contains": { "body": "\"checkout\":\"2026-04-05\"" }
      }
    ],
    "responses": [
      {
        "is": {
          "statusCode": 400,
          "headers": { "Content-Type": "application/json" },
          "body": {
            "error": "datas_invalidas",
            "message": "checkout não pode ser anterior ao checkin"
          }
        }
      }
    ]
  }
}

### stub POST quarto cheio (específico - segundo!)
POST http://localhost:2525/imposters/3003/stubs
Content-Type: application/json

{
  "stub": {
    "predicates": [
      {
        "equals": {
          "method": "POST",
          "path": "/api/reservas",
          "headers": { "Content-Type": "application/json" }
        }
      },
      {
        "contains": { "body": "\"tipo_quarto\":\"cheio\"" }
      }
    ],
    "responses": [
      {
        "is": {
          "statusCode": 409,
          "headers": { "Content-Type": "application/json" },
          "body": {
            "error": "sem_disponibilidade",
            "message": "Sem disponibilidade"
          }
        }
      }
    ]
  }
}

### stub POST sucesso (genérico - depois!)
POST http://localhost:2525/imposters/3003/stubs
Content-Type: application/json

{
  "stub": {
    "predicates": [
      {
        "equals": {
          "method": "POST",
          "path": "/api/reservas",
          "headers": { "Content-Type": "application/json" }
        }
      }
    ],
    "responses": [
      {
        "is": {
          "statusCode": 201,
          "headers": { "Content-Type": "application/json" },
          "body": {
            "id": 3,
            "status": "created",
            "message": "reserva criada com sucesso"
          }
        }
      }
    ]
  }
}

