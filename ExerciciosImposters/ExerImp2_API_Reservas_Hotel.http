Content-Type: application/json

{
  "stub": {
    "predicates": [
      {
        "equals": {
          "method": "PUT",
          "path": "/api/reservas/1",
          "headers": { "Content-Type": "application/json" }
        }
      }
    ],
    "responses": [
      {
        "is": {
