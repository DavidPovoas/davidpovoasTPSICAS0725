#-----------------------------------------------------

# DELETE /api/alunos/{id} - admin pode apagar

### adicionar stub
POST http://localhost:2525/imposters/3001/stubs
Content-Type: application/json

{
  "stub": {
    "predicates": [
      {
        "equals": {
          "method": "DELETE",
          "path": "/api/alunos/1",
          "headers": { "Authorization": "Bearer admintoken" }
        }
      }
    ],
    "responses": [
      {
        "is": {
          "statusCode": 200,
          "headers": { "Content-Type": "application/json" },
          "body": {
            "status": "deleted",
            "message": "aluno removido com sucesso"
          }
        }
      }
    ]
  }
}

#-----------------------------------------------------

# DELETE /api/alunos/{id} - sem permissões

### adicionar stub
POST http://localhost:2525/imposters/3001/stubs
Content-Type: application/json

{
  "stub": {
    "predicates": [
      {
        "equals": {
          "method": "DELETE",
          "path": "/api/alunos/1"
        }
      }
    ],
    "responses": [
      {
        "is": {
          "statusCode": 403,
          "headers": { "Content-Type": "application/json" },
          "body": {
            "error": "forbidden",
            "message": "só administradores podem apagar alunos"
          }
        }
      }
    ]
  }
}

### testar delete com permissão
DELETE http://localhost:3001/api/alunos/1
Authorization: Bearer admintoken

