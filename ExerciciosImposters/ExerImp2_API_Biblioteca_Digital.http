#-----------------------------------------------------

# POST /api/emprestimos - livro já emprestado (específico - primeiro!)

### adicionar stub
POST http://localhost:2525/imposters/3004/stubs
Content-Type: application/json

{
  "stub": {
    "predicates": [
      {
        "equals": {
          "method": "POST",
          "path": "/api/emprestimos",
          "headers": { "Content-Type": "application/json" }
        }
      },
      {
        "contains": { "body": "\"livro_id\":2" }
      }
    ],
    "responses": [
      {
        "is": {
          "statusCode": 409,
          "headers": { "Content-Type": "application/json" },
          "body": {
            "error": "livro_emprestado",
            "message": "este livro já se encontra emprestado"
          }
        }
      }
    ]
  }
}

### testar livro já emprestado
POST http://localhost:3004/api/emprestimos
Content-Type: application/json

{"cliente":"David","livro_id":2,"data_emprestimo":"2026-04-06"}

#-----------------------------------------------------

# POST /api/emprestimos - sucesso (genérico - depois!)

### adicionar stub
POST http://localhost:2525/imposters/3004/stubs
Content-Type: application/json

{
  "stub": {
    "predicates": [
      {
        "equals": {
          "method": "POST",
          "path": "/api/emprestimos",
          "headers": { "Content-Type": "application/json" }
        }
      }
    ],
    "responses": [
      {
        "is": {
          "statusCode": 201,
          "headers": { "Content-Type": "application/json" },
          "body": {
            "id": 1,
            "status": "created",
            "message": "empréstimo registado com sucesso"
          }
        }
      }
    ]
  }
}

### testar emprestimo válido
POST http://localhost:3004/api/emprestimos
Content-Type: application/json

{"cliente":"David","livro_id":1,"data_emprestimo":"2026-04-06"}

