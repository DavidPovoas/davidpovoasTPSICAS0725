Content-Type: application/json

{
  "stub": {
    "predicates": [
      {
        "equals": {
          "method": "DELETE",
          "path": "/api/livros/1"
        }
      }
    ],
    "responses": [
      {
        "is": {
          "statusCode": 200,
          "headers": { "Content-Type": "application/json" },
